# Environment Variables – RiskIntelligenceEngine
# Copy this to .env and fill in your values

# ─── Application ──────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production-use-256bit-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aml_user:aml_pass@postgres:5432/aml_db
DATABASE_URL_SYNC=postgresql://aml_user:aml_pass@postgres:5432/aml_db

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Kafka ────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=aml-consumer-group

# ─── Neo4j ────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=amlpassword

# ─── Service URLs (internal) ──────────────────
FEATURE_SERVICE_URL=http://feature-engineering:8003
RULE_SERVICE_URL=http://rule-engine:8004
ML_SERVICE_URL=http://ml-scoring:8005
GRAPH_SERVICE_URL=http://graph-intelligence:8006
AGGREGATION_SERVICE_URL=http://risk-aggregation:8007
ALERT_SERVICE_URL=http://alert-service:8008

# ─── ML Model ─────────────────────────────────
MODEL_VERSION=AML_GB_v4.1
MODEL_PATH=/app/models/saved/aml_model.joblib

# ─── Risk Thresholds ─────────────────────────
RISK_LOW_MAX=30
RISK_MEDIUM_MAX=60
RISK_HIGH_MAX=80

# ─── Logging ─────────────────────────────────
LOG_LEVEL=INFO
